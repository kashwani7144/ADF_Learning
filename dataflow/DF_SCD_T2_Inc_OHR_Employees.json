{
	"name": "DF_SCD_T2_Inc_OHR_Employees",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_OHR_EMPLOYEES_3003",
						"type": "DatasetReference"
					},
					"name": "OHREmployeesSrc"
				},
				{
					"dataset": {
						"referenceName": "DS_DIM_EMP_DETAILS_3003",
						"type": "DatasetReference"
					},
					"name": "DimEmployeeDetails"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_DIM_EMPLOYEE_0104",
						"type": "DatasetReference"
					},
					"name": "DwhDimEmployeeInsert"
				},
				{
					"dataset": {
						"referenceName": "DS_DIM_EMPLOYEE_0104",
						"type": "DatasetReference"
					},
					"name": "DwhDimEmployeeUpdate"
				}
			],
			"transformations": [
				{
					"name": "SourceJoinDimension"
				},
				{
					"name": "SelectDistinctColumns"
				},
				{
					"name": "DcTrackChanges"
				},
				{
					"name": "CheckNewOrChangedRow"
				},
				{
					"name": "NewRowsUnionChangedRows"
				},
				{
					"name": "DcAddMetadataColumns"
				},
				{
					"name": "DcExpiredRowSetup"
				},
				{
					"name": "UpdateRowCondition"
				},
				{
					"name": "FilterActiveRows"
				}
			],
			"scriptLines": [
				"source(output(",
				"          EMPLOYEE_ID as string,",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL as string,",
				"          PHONE_NUMBER as string,",
				"          HIRE_DATE as timestamp,",
				"          JOB_ID as string,",
				"          SALARY as decimal(8,2),",
				"          COMMISSION_PCT as decimal(2,2),",
				"          MANAGER_ID as integer,",
				"          DEPARTMENT_ID as integer,",
				"          SRC_ROW_INSERT_TSTMP as timestamp,",
				"          INSERT_TSTMP_IST as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     waterMarkColumn: 'INSERT_TSTMP_IST',",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     mode: 'read') ~> OHREmployeesSrc",
				"source(output(",
				"          EMPLOYEE_SID as integer,",
				"          EMPLOYEE_ID as string,",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL as string,",
				"          PHONE_NUMBER as string,",
				"          HIRE_DATE as timestamp,",
				"          JOB_ID as string,",
				"          SALARY as decimal(8,2),",
				"          COMMISSION_PCT as decimal(2,2),",
				"          MANAGER_ID as integer,",
				"          DEPARTMENT_ID as integer,",
				"          SRC_ROW_INSERT_TSTMP as timestamp,",
				"          WATERMARK_VALUE as string,",
				"          FILE_TABLE_ID as integer,",
				"          BATCH_ID as integer,",
				"          SRC_TBL_NM as string,",
				"          PIPELINE_NAME as string,",
				"          ROW_VERSION as binary,",
				"          WATERMARK_ID as integer,",
				"          ROW_EFF_DT as date,",
				"          ROW_EXPIR_DT as date,",
				"          ROW_STS_CD as string,",
				"          INSERT_TSTMP_IST as timestamp,",
				"          LST_UPD_TSTMP_IST as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> DimEmployeeDetails",
				"OHREmployeesSrc, FilterActiveRows join(OHREmployeesSrc@EMPLOYEE_ID == DimEmployeeDetails@EMPLOYEE_ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> SourceJoinDimension",
				"SourceJoinDimension select(mapColumn(",
				"          EMPLOYEE_ID = OHREmployeesSrc@EMPLOYEE_ID,",
				"          FIRST_NAME = OHREmployeesSrc@FIRST_NAME,",
				"          LAST_NAME = OHREmployeesSrc@LAST_NAME,",
				"          EMAIL = OHREmployeesSrc@EMAIL,",
				"          PHONE_NUMBER = OHREmployeesSrc@PHONE_NUMBER,",
				"          HIRE_DATE = OHREmployeesSrc@HIRE_DATE,",
				"          JOB_ID = OHREmployeesSrc@JOB_ID,",
				"          SALARY = OHREmployeesSrc@SALARY,",
				"          COMMISSION_PCT = OHREmployeesSrc@COMMISSION_PCT,",
				"          MANAGER_ID = OHREmployeesSrc@MANAGER_ID,",
				"          DEPARTMENT_ID = OHREmployeesSrc@DEPARTMENT_ID,",
				"          SRC_ROW_INSERT_TSTMP = OHREmployeesSrc@SRC_ROW_INSERT_TSTMP,",
				"          INSERT_TSTMP_IST = OHREmployeesSrc@INSERT_TSTMP_IST,",
				"          EMPLOYEE_SID,",
				"          TGT_EMPLOYEE_ID = DimEmployeeDetails@EMPLOYEE_ID,",
				"          TGT_FIRST_NAME = DimEmployeeDetails@FIRST_NAME,",
				"          TGT_LAST_NAME = DimEmployeeDetails@LAST_NAME,",
				"          TGT_EMAIL = DimEmployeeDetails@EMAIL,",
				"          TGT_PHONE_NUMBER = DimEmployeeDetails@PHONE_NUMBER,",
				"          TGT_HIRE_DATE = DimEmployeeDetails@HIRE_DATE,",
				"          TGT_JOB_ID = DimEmployeeDetails@JOB_ID,",
				"          TGT_SALARY = DimEmployeeDetails@SALARY,",
				"          TGT_COMMISSION_PCT = DimEmployeeDetails@COMMISSION_PCT,",
				"          TGT_MANAGER_ID = DimEmployeeDetails@MANAGER_ID,",
				"          TGT_DEPARTMENT_ID = DimEmployeeDetails@DEPARTMENT_ID,",
				"          TGT_SRC_ROW_INSERT_TSTMP = DimEmployeeDetails@SRC_ROW_INSERT_TSTMP",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectDistinctColumns",
				"SelectDistinctColumns derive(isChanged = iif(\r",
				"     md5(EMPLOYEE_ID)  != md5(TGT_EMPLOYEE_ID)  ||\r",
				"    md5(FIRST_NAME) != md5(TGT_FIRST_NAME) ||\r",
				"    md5(LAST_NAME)  != md5(TGT_LAST_NAME)  ||\r",
				"     md5(EMAIL)      != md5(TGT_EMAIL)      ||\r",
				"    md5(PHONE_NUMBER)    != md5(TGT_PHONE_NUMBER)    ||\r",
				"    md5(HIRE_DATE)       != md5(TGT_HIRE_DATE)       ||\r",
				"    md5(JOB_ID)    != md5(TGT_JOB_ID)    ||\r",
				"    md5(SALARY)    != md5(TGT_SALARY)    ||\r",
				"    md5(COMMISSION_PCT)    != md5(TGT_COMMISSION_PCT)    ||\r",
				"    \r",
				"    md5(MANAGER_ID) != md5(TGT_MANAGER_ID) ||\r",
				"    md5(DEPARTMENT_ID)    != md5(TGT_DEPARTMENT_ID),\r",
				"    true(),\r",
				"    false()\r",
				")) ~> DcTrackChanges",
				"DcTrackChanges split(isNull(TGT_EMPLOYEE_ID),",
				"     !isNull(TGT_EMPLOYEE_ID) && (\r",
				"  coalesce(FIRST_NAME , '') != coalesce(TGT_FIRST_NAME , '') ||\r",
				"  coalesce(LAST_NAME  , '') != coalesce(TGT_LAST_NAME  , '') ||\r",
				"  coalesce(EMAIL      , '') != coalesce(TGT_EMAIL      , '') || \r",
				"  coalesce(PHONE_NUMBER, '') != coalesce(TGT_PHONE_NUMBER, '') ||\r",
				"  coalesce(HIRE_DATE, toDate('1900-01-01')) != coalesce(TGT_HIRE_DATE, toDate('1900-01-01')) ||\r",
				"  coalesce(JOB_ID, '') != coalesce(TGT_JOB_ID, '') ||\r",
				"  coalesce(SALARY, 0) != coalesce(TGT_SALARY, 0) ||\r",
				"  coalesce(COMMISSION_PCT, 0.0) != coalesce(TGT_COMMISSION_PCT, 0.0) ||\r",
				"  coalesce(MANAGER_ID, 0) != coalesce(TGT_MANAGER_ID, 0) ||\r",
				"  coalesce(DEPARTMENT_ID, 0) != coalesce(TGT_DEPARTMENT_ID, 0)\r",
				"),",
				"     disjoint: false) ~> CheckNewOrChangedRow@(NewRows, ChangedRows)",
				"CheckNewOrChangedRow@NewRows, CheckNewOrChangedRow@ChangedRows union(byName: true)~> NewRowsUnionChangedRows",
				"NewRowsUnionChangedRows derive(WATERMARK_VALUE = 3,",
				"          BATCH_ID = toInteger(toString(currentDate(), 'yyyyMMdd')),",
				"          ROW_EFF_DT = currentDate(),",
				"          ROW_EXPIR_DT = toDate('9999-12-31'),",
				"          ROW_STS_CD = 'A',",
				"          PIPELINE_NAME = 'P_DF_SCD_T2_Inc_OHR_Employees') ~> DcAddMetadataColumns",
				"CheckNewOrChangedRow@ChangedRows derive(ROW_STS_CD = 'I',",
				"          ROW_EXPIR_DT = toDate(fromUTC(currentUTC(), 'India Standard Time')),",
				"          LST_UPD_TSTMP_IST = fromUTC(currentUTC(), 'India Standard Time')) ~> DcExpiredRowSetup",
				"DcExpiredRowSetup alterRow(updateIf(!isNull(EMPLOYEE_SID))) ~> UpdateRowCondition",
				"DimEmployeeDetails filter(ROW_STS_CD == 'A' && ROW_EXPIR_DT == toDate('9999-12-31')) ~> FilterActiveRows",
				"DcAddMetadataColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EMPLOYEE_SID as integer,",
				"          EMPLOYEE_ID as string,",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL as string,",
				"          PHONE_NUMBER as string,",
				"          HIRE_DATE as timestamp,",
				"          JOB_ID as string,",
				"          SALARY as decimal(8,2),",
				"          COMMISSION_PCT as decimal(2,2),",
				"          MANAGER_ID as integer,",
				"          DEPARTMENT_ID as integer,",
				"          SRC_ROW_INSERT_TSTMP as timestamp,",
				"          WATERMARK_VALUE as string,",
				"          FILE_TABLE_ID as integer,",
				"          BATCH_ID as integer,",
				"          SRC_TBL_NM as string,",
				"          PIPELINE_NAME as string,",
				"          ROW_VERSION as binary,",
				"          WATERMARK_ID as integer,",
				"          ROW_EFF_DT as date,",
				"          ROW_EXPIR_DT as date,",
				"          ROW_STS_CD as string,",
				"          INSERT_TSTMP_IST as timestamp,",
				"          LST_UPD_TSTMP_IST as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          EMPLOYEE_ID,",
				"          FIRST_NAME,",
				"          LAST_NAME,",
				"          EMAIL,",
				"          PHONE_NUMBER,",
				"          HIRE_DATE,",
				"          JOB_ID,",
				"          SALARY,",
				"          COMMISSION_PCT,",
				"          MANAGER_ID,",
				"          DEPARTMENT_ID,",
				"          SRC_ROW_INSERT_TSTMP,",
				"          WATERMARK_VALUE,",
				"          BATCH_ID,",
				"          PIPELINE_NAME,",
				"          WATERMARK_ID = WATERMARK_VALUE",
				"     )) ~> DwhDimEmployeeInsert",
				"UpdateRowCondition sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EMPLOYEE_SID as integer,",
				"          EMPLOYEE_ID as string,",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL as string,",
				"          PHONE_NUMBER as string,",
				"          HIRE_DATE as timestamp,",
				"          JOB_ID as string,",
				"          SALARY as decimal(8,2),",
				"          COMMISSION_PCT as decimal(2,2),",
				"          MANAGER_ID as integer,",
				"          DEPARTMENT_ID as integer,",
				"          SRC_ROW_INSERT_TSTMP as timestamp,",
				"          WATERMARK_VALUE as string,",
				"          FILE_TABLE_ID as integer,",
				"          BATCH_ID as integer,",
				"          SRC_TBL_NM as string,",
				"          PIPELINE_NAME as string,",
				"          ROW_VERSION as binary,",
				"          WATERMARK_ID as integer,",
				"          ROW_EFF_DT as date,",
				"          ROW_EXPIR_DT as date,",
				"          ROW_STS_CD as string,",
				"          INSERT_TSTMP_IST as timestamp,",
				"          LST_UPD_TSTMP_IST as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['EMPLOYEE_SID'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> DwhDimEmployeeUpdate"
			]
		}
	}
}